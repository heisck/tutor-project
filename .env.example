NODE_ENV=development
PORT=4000
APP_VERSION=0.1.0
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ai_tutor_pwa?schema=public
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:3000,https://app.domain.com
COOKIE_SECRET=replace-with-a-long-random-secret-at-least-32-characters
SESSION_TTL_HOURS=168
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/oauth/callback
R2_ENDPOINT=https://example-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET_NAME=ai-tutor-pwa-private
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
