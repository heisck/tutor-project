generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum UserRole {
  STUDENT
  ADMIN
}

enum DocumentProcessingStatus {
  PENDING
  QUEUED
  PROCESSING
  EXTRACTING
  INDEXING
  COMPLETE
  FAILED
  RETRYING
}

enum DocumentSectionKind {
  TEXT
  HEADING
  LIST
  TABLE
  FORMULA
  CAPTION
}

enum DocumentAssetKind {
  IMAGE
  DIAGRAM
}

enum AcademicLevel {
  HIGH_SCHOOL
  UNDERGRADUATE
  POSTGRADUATE
  PROFESSIONAL
}

enum SourceUnitCategory {
  TEXT
  HEADING
  LIST
  TABLE
  FORMULA
  CAPTION
  VISUAL
}

enum AtuCategory {
  CONCEPT
  FACT
  PROCEDURE
  PRINCIPLE
  DEFINITION
}

enum AtuDifficulty {
  INTRODUCTORY
  INTERMEDIATE
  ADVANCED
}

enum CoverageStatus {
  NOT_TAUGHT
  IN_PROGRESS
  TAUGHT
  ASSESSED
}

enum StudySessionMode {
  FULL
  SUMMARY
  FLASHCARDS
  QUIZ
  DIFFICULT_PARTS
  IMAGES
  VOICE
  EXAM
  REVISION
}

enum StudySessionStatus {
  CREATED
  ACTIVE
  PAUSED
  ABANDONED
  COMPLETED
  INCOMPLETE
}

enum MotivationState {
  NEUTRAL
  ENCOURAGED
  CHALLENGED
  FRUSTRATED
}

enum StudyGoalPreference {
  PASS_EXAM
  DEEP_UNDERSTANDING
  QUICK_OVERVIEW
  BUILD_PROJECT
}

enum ExplanationStartPreference {
  EXAMPLE_FIRST
  DIRECT
  WHY_FIRST
}

enum LessonSegmentExplanationStrategy {
  EXAMPLE_FIRST
  DIRECT
  WHY_FIRST
}

enum FeedbackContentType {
  TUTOR_EXPLANATION
  ASSISTANT_ANSWER
}

enum FeedbackReason {
  HALLUCINATION
  POOR_EXPLANATION
}

enum FeedbackAlertStatus {
  PENDING_REVIEW
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  authProvider  AuthProvider
  emailVerified Boolean       @default(false)
  username      String?
  institutionId String?
  department    String?
  level         String?
  role          UserRole      @default(STUDENT)
  passwordHash  String?
  googleSubject String?       @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  institution   Institution?  @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  courses       Course[]
  documents     Document[]
  documentAssets   DocumentAsset[]
  documentSections DocumentSection[]
  sourceUnits      SourceUnit[]
  documentChunks   DocumentChunk[]
  atus             AtomicTeachableUnit[]
  concepts         Concept[]
  misconceptions   Misconception[]
  coverageLedger   CoverageLedger[]
  lessonSegments   LessonSegment[]
  handoffSnapshots SessionHandoffSnapshot[]
  userFeedback     UserFeedback[]
  sessions         AuthSession[]
  studySessions    StudySession[]
  aiRuntimeUsages  AiRuntimeUsage[]
  learningProfile  LearningProfile?

  @@index([institutionId])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Institution {
  id        String   @id @default(cuid())
  name      String   @unique
  country   String?
  type      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model LearningProfile {
  id                         String                     @id @default(cuid())
  userId                     String                     @unique
  academicLevel              AcademicLevel
  studyGoalPreference        StudyGoalPreference
  explanationStartPreference ExplanationStartPreference
  lastCalibratedAt           DateTime?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  user                       User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  studySessions              StudySession[]
}

model Course {
  id        String   @id @default(cuid())
  userId    String
  name      String
  code      String?
  level     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  documents Document[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Document {
  id               String                   @id @default(cuid())
  userId           String
  courseId         String?
  title            String
  fileUrl          String
  fileType         String
  fileSize         Int
  processingStatus DocumentProcessingStatus @default(PENDING)
  supersededBy     String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  course           Course?                  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets           DocumentAsset[]
  nextVersion      Document?                @relation("DocumentSupersession", fields: [supersededBy], references: [id], onDelete: SetNull)
  previousVersions Document[]               @relation("DocumentSupersession")
  sections         DocumentSection[]
  sourceUnits      SourceUnit[]
  chunks           DocumentChunk[]
  atus                  AtomicTeachableUnit[]
  concepts              Concept[]
  conceptPrerequisites  ConceptPrerequisite[]
  misconceptions        Misconception[]
  coverageLedger        CoverageLedger[]
  lessonSegments        LessonSegment[]
  handoffSnapshots      SessionHandoffSnapshot[]
  studySessions         StudySession[]
  userFeedback          UserFeedback[]
  feedbackAlerts        FeedbackAlert[]
  aiRuntimeUsages       AiRuntimeUsage[]

  @@index([courseId])
  @@index([processingStatus])
  @@index([userId])
}

model DocumentSection {
  id          String              @id @default(cuid())
  documentId  String
  userId      String
  ordinal     Int
  kind        DocumentSectionKind
  title       String?
  content     String
  sourceTrace Json
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  assets      DocumentAsset[]
  sourceUnits SourceUnit[]
  lessonSegments LessonSegment[]
  document    Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentForSessions StudySession[] @relation("StudySessionCurrentSection")

  @@index([documentId])
  @@index([userId])
  @@unique([documentId, ordinal])
}

model DocumentAsset {
  id          String            @id @default(cuid())
  documentId  String
  userId      String
  sectionId   String?
  ordinal     Int
  kind        DocumentAssetKind
  storageKey  String
  mimeType    String
  title       String?
  description String?
  width       Int?
  height      Int?
  sourceTrace Json
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  sourceUnits SourceUnit[]
  document    Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  section     DocumentSection?  @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([sectionId])
  @@index([userId])
  @@unique([documentId, ordinal])
}

model SourceUnit {
  id          String             @id @default(cuid())
  documentId  String
  userId      String
  sectionId   String?
  assetId     String?
  ordinal     Int
  category    SourceUnitCategory
  content     String
  title       String?
  sourceTrace Json
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  document    Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  section     DocumentSection?   @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  asset       DocumentAsset?     @relation(fields: [assetId], references: [id], onDelete: SetNull)
  chunks      DocumentChunk[]
  atus        AtomicTeachableUnit[]

  @@index([documentId])
  @@index([userId])
  @@unique([documentId, ordinal])
}

model DocumentChunk {
  id           String                      @id @default(cuid())
  documentId   String
  userId       String
  sourceUnitId String
  ordinal      Int
  content      String
  tokenCount   Int
  embedding    Unsupported("vector(1536)")?
  sourceTrace  Json
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
  document     Document                    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user         User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceUnit   SourceUnit                  @relation(fields: [sourceUnitId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId])
  @@index([sourceUnitId])
  @@unique([documentId, ordinal])
}

model AtomicTeachableUnit {
  id            String        @id @default(cuid())
  documentId    String
  userId        String
  sourceUnitId  String
  conceptId     String?
  ordinal       Int
  title         String
  content       String
  category      AtuCategory
  difficulty    AtuDifficulty
  examRelevance Boolean       @default(false)
  isImplied     Boolean       @default(false)
  sourceTrace   Json
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  document      Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceUnit    SourceUnit    @relation(fields: [sourceUnitId], references: [id], onDelete: Cascade)
  concept       Concept?      @relation(fields: [conceptId], references: [id], onDelete: SetNull)
  coverageLedger CoverageLedger[]

  @@index([documentId])
  @@index([userId])
  @@index([sourceUnitId])
  @@index([conceptId])
  @@unique([documentId, ordinal])
}

model Concept {
  id               String                @id @default(cuid())
  documentId       String
  userId           String
  title            String
  description      String
  ordinal          Int
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  document         Document              @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  atus             AtomicTeachableUnit[]
  lessonSegments   LessonSegment[]
  misconceptions   Misconception[]
  userFeedback     UserFeedback[]
  feedbackAlerts   FeedbackAlert[]
  prerequisiteFor  ConceptPrerequisite[] @relation("PrerequisiteConcept")
  dependsOn        ConceptPrerequisite[] @relation("DependentConcept")

  @@index([documentId])
  @@index([userId])
  @@unique([documentId, ordinal])
}

model ConceptPrerequisite {
  id              String   @id @default(cuid())
  documentId      String
  prerequisiteId  String
  dependentId     String
  createdAt       DateTime @default(now())
  document        Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  prerequisite    Concept  @relation("PrerequisiteConcept", fields: [prerequisiteId], references: [id], onDelete: Cascade)
  dependent       Concept  @relation("DependentConcept", fields: [dependentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([prerequisiteId])
  @@index([dependentId])
  @@unique([prerequisiteId, dependentId])
}

model Misconception {
  id          String   @id @default(cuid())
  documentId  String
  userId      String
  conceptId   String
  title       String
  description String
  severity    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept     Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([conceptId])
  @@index([userId])
}

model CoverageLedger {
  id        String         @id @default(cuid())
  documentId String
  userId    String
  atuId     String
  status    CoverageStatus @default(NOT_TAUGHT)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  document  Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  atu       AtomicTeachableUnit @relation(fields: [atuId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId])
  @@index([atuId])
  @@unique([documentId, atuId])
}

model StudySession {
  id                   String             @id @default(cuid())
  userId               String
  documentId           String
  learningProfileId    String?
  mode                 StudySessionMode   @default(FULL)
  status               StudySessionStatus @default(CREATED)
  currentSectionId     String?
  currentSegmentId     String?
  currentStep          Int                @default(0)
  frustrationFlagCount Int                @default(0)
  motivationState      MotivationState    @default(NEUTRAL)
  startedAt            DateTime?
  lastActiveAt         DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  document             Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentSection       DocumentSection?   @relation("StudySessionCurrentSection", fields: [currentSectionId], references: [id], onDelete: SetNull)
  currentSegment       LessonSegment?     @relation("StudySessionCurrentSegment", fields: [currentSegmentId], references: [id], onDelete: SetNull)
  learningProfile      LearningProfile?   @relation(fields: [learningProfileId], references: [id], onDelete: SetNull)
  lessonSegments       LessonSegment[]
  handoffSnapshot      SessionHandoffSnapshot?
  userFeedback         UserFeedback[]
  aiRuntimeUsages      AiRuntimeUsage[]

  @@index([documentId])
  @@index([learningProfileId])
  @@index([status])
  @@index([userId])
}

model AiRuntimeUsage {
  id               String       @id @default(cuid())
  userId           String
  studySessionId   String
  documentId       String
  route            String
  outcome          String
  providerCallCount Int        @default(0)
  inputTokenCount  Int         @default(0)
  outputTokenCount Int         @default(0)
  metadata         Json?
  createdAt        DateTime    @default(now())
  document         Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  studySession     StudySession @relation(fields: [studySessionId], references: [id], onDelete: Cascade)
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
  @@index([studySessionId, createdAt])
  @@index([userId, createdAt])
}

model LessonSegment {
  id                    String                           @id @default(cuid())
  studySessionId        String
  documentId            String
  userId                String
  conceptId             String
  sectionId             String?
  ordinal               Int
  sourceOrdinal         Int
  explanationStrategy   LessonSegmentExplanationStrategy
  conceptTitle          String
  conceptDescription    String
  analogyPrompt         String
  checkPrompt           String
  masteryGate           Json
  coverageSummary       Json
  atuIds                String[]
  sourceUnitIds         String[]
  chunkIds              String[]
  prerequisiteConceptIds String[]
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt
  studySession          StudySession                     @relation(fields: [studySessionId], references: [id], onDelete: Cascade)
  document              Document                         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user                  User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept               Concept                          @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  section               DocumentSection?                 @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  currentForSessions    StudySession[]                   @relation("StudySessionCurrentSegment")
  userFeedback          UserFeedback[]
  feedbackAlerts        FeedbackAlert[]

  @@index([conceptId])
  @@index([documentId])
  @@index([sectionId])
  @@index([studySessionId])
  @@index([userId])
  @@unique([studySessionId, ordinal])
}

model SessionHandoffSnapshot {
  id                 String       @id @default(cuid())
  studySessionId     String       @unique
  documentId         String
  userId             String
  currentSegmentId   String
  currentSectionId   String?
  currentStep        Int          @default(0)
  masterySnapshot    Json
  unresolvedAtuIds   String[]
  explanationHistory Json
  resumeNotes        String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  studySession       StudySession @relation(fields: [studySessionId], references: [id], onDelete: Cascade)
  document           Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([userId])
}

model UserFeedback {
  id             String              @id @default(cuid())
  userId         String
  studySessionId String
  documentId     String
  conceptId      String
  lessonSegmentId String
  contentType    FeedbackContentType
  reason         FeedbackReason
  messageId      String?
  scopeKey       String
  createdAt      DateTime            @default(now())
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  studySession   StudySession        @relation(fields: [studySessionId], references: [id], onDelete: Cascade)
  document       Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  concept        Concept             @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  lessonSegment  LessonSegment       @relation(fields: [lessonSegmentId], references: [id], onDelete: Cascade)

  @@index([conceptId])
  @@index([documentId])
  @@index([lessonSegmentId])
  @@index([reason, scopeKey])
  @@index([studySessionId])
  @@index([userId])
}

model FeedbackAlert {
  id             String              @id @default(cuid())
  scopeKey       String              @unique
  documentId     String
  conceptId      String
  lessonSegmentId String?
  contentType    FeedbackContentType
  reason         FeedbackReason
  feedbackCount  Int
  threshold      Int
  status         FeedbackAlertStatus @default(PENDING_REVIEW)
  triggeredAt    DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  document       Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  concept        Concept             @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  lessonSegment  LessonSegment?      @relation(fields: [lessonSegmentId], references: [id], onDelete: SetNull)

  @@index([conceptId])
  @@index([documentId])
  @@index([lessonSegmentId])
}
