generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum UserRole {
  STUDENT
  ADMIN
}

enum DocumentProcessingStatus {
  PENDING
  QUEUED
  PROCESSING
  EXTRACTING
  INDEXING
  COMPLETE
  FAILED
  RETRYING
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  authProvider  AuthProvider
  emailVerified Boolean       @default(false)
  username      String?
  institutionId String?
  department    String?
  level         String?
  role          UserRole      @default(STUDENT)
  passwordHash  String?
  googleSubject String?       @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  institution   Institution?  @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  courses       Course[]
  documents     Document[]
  sessions      AuthSession[]

  @@index([institutionId])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Institution {
  id        String   @id @default(cuid())
  name      String   @unique
  country   String?
  type      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model Course {
  id        String   @id @default(cuid())
  userId    String
  name      String
  code      String?
  level     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  documents Document[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Document {
  id               String                   @id @default(cuid())
  userId           String
  courseId         String?
  title            String
  fileUrl          String
  fileType         String
  fileSize         Int
  processingStatus DocumentProcessingStatus @default(PENDING)
  supersededBy     String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  course           Course?                  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nextVersion      Document?                @relation("DocumentSupersession", fields: [supersededBy], references: [id], onDelete: SetNull)
  previousVersions Document[]               @relation("DocumentSupersession")

  @@index([courseId])
  @@index([processingStatus])
  @@index([userId])
}
