{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
    "types": [
      "node"
    ]
  },
  "references": [
    {
      "path": "../shared"
    },
    {
      "path": "../db"
    }
  ],
  "include": [
    "src/**/*",
    "tests/**/*",
    "vitest.config.ts"
  ]
}
