{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@ai-tutor-pwa/shared": [
        "../shared/src/index.ts"
      ],
      "@ai-tutor-pwa/db": [
        "../db/src/index.ts"
      ]
    }
  },
  "references": [
    {
      "path": "../shared"
    },
    {
      "path": "../db"
    }
  ],
  "include": [
    "src/**/*",
    "tests/**/*",
    "vitest.config.ts"
  ]
}
