# API Environment Configuration
# Copy this file to .env.local and fill in the actual values for development

# OpenAI API key for AI features
OPENAI_API_KEY=sk-test-key-here

# Anthropic API key (Claude)
ANTHROPIC_API_KEY=sk-ant-test-key-here

# Database connection
DATABASE_URL=postgresql://user:password@localhost:5432/ai_tutor

# Redis cache
REDIS_URL=redis://localhost:6379

# Google OAuth (for social auth)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Cloudflare R2 (S3-compatible object storage)
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=ai-tutor-uploads
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# Session configuration
SESSION_TTL_HOURS=168

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Cookie secret (generate with: openssl rand -base64 32)
COOKIE_SECRET=your-32-character-cookie-secret-here

# Server port
PORT=3001

# Environment
NODE_ENV=development

# App version
APP_VERSION=0.1.0
