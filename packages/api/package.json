{
  "name": "@ai-tutor-pwa/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "dotenv -e ../../.env.local -- tsx watch src/index.ts",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "start": "dotenv -e ../../.env.local -- node dist/index.js"
  },
  "dependencies": {
    "@ai-tutor-pwa/db": "*",
    "@ai-tutor-pwa/shared": "*",
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2"
  }
}
