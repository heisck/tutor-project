{
  "name": "@ai-tutor-pwa/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "dotenv -e ../../.env.local -- tsx watch src/index.ts",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "start": "dotenv -e ../../.env.local -- node dist/index.js"
  },
  "dependencies": {
    "@ai-tutor-pwa/db": "*",
    "@ai-tutor-pwa/shared": "*",
    "@anthropic-ai/sdk": "^0.88.0",
    "@aws-sdk/client-s3": "^3.916.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.2.1",
    "bullmq": "^5.58.4",
    "fast-xml-parser": "^5.5.8",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "js-tiktoken": "^1.0.21",
    "jszip": "^3.10.1",
    "openai": "^6.34.0",
    "openid-client": "^6.8.1",
    "pdfjs-dist": "^5.6.205",
    "unpdf": "^1.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2"
  }
}
