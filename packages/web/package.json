{
  "name": "@ai-tutor-pwa/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "dotenv -e ../../.env.local -- next dev --port 3000",
    "lint": "eslint .",
    "typecheck": "dotenv -e ../../.env.local -- next typegen && tsc --noEmit --incremental false",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "start": "dotenv -e ../../.env.local -- next start --port 3000"
  },
  "dependencies": {
    "@ai-tutor-pwa/shared": "*",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "tailwindcss": "^4.2.2"
  }
}
